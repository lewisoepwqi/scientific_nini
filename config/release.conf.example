; =============================================================================
; Nini 发布配置模板
; 复制此文件为 config/release.conf 并根据实际情况修改
; =============================================================================
; ⚠️ 此文件包含服务器敏感信息，config/release.conf 已加入 .gitignore
;
; 使用方式：
;   1. 复制此模板：cp config/release.conf.example config/release.conf
;   2. 编辑 config/release.conf，填入实际的服务器信息
;   3. 运行 build_windows.bat 时自动读取此配置生成上传脚本
; =============================================================================

[server]
; 更新服务器基础 URL（客户端 .env 里的 NINI_UPDATE_BASE_URL 应与之一致）
; 必须以 / 结尾，且包含渠道段
url = http://121.41.97.123:1116/nini/updates/

; 更新渠道：stable（稳定版）或 beta（测试版）
; 客户端 .env 里的 NINI_UPDATE_CHANNEL 应与之一致
channel = stable

; 是否允许 HTTP 下载（IP/localhost 场景需开启）
; 生产环境建议使用 HTTPS，此时设为 false
allow_insecure_http = true

; SSH 上传信息（用于生成 upload.bat / upload.ps1）
ssh_user = lewis
ssh_host = 121.41.97.123

; 服务器上的上传目标目录
; 上传后会形成：{upload_path}/latest.json
;               {upload_path}/Nini-x.y.z-Setup.exe
upload_path = /opt/nini-updates/public/nini/updates/stable

[release]
; 默认更新说明（打包时会提示确认，可覆盖）
; 用 | 分隔多条说明，前端会按列表展示
default_notes = 修复若干问题|新增导出功能|优化启动速度
