# 忽略运行时数据文件
*
!.gitignore

# nini AI 指令（项目级配置，纳入版本管理）
!AGENTS.md

# 保留打包需要的静态资源目录
!fonts/
!fonts/**
!prompt_components/
!prompt_components/**

# 保留内置知识库静态内容
!knowledge/
!knowledge/metadata.json
!knowledge/methods/
!knowledge/methods/*.md
!knowledge/pitfalls/
!knowledge/pitfalls/*.md
!knowledge/reporting/
!knowledge/reporting/*.md

# 保留 autoresearch 基准配置
!autoresearch/
autoresearch/*
!autoresearch/harness_benchmarks.yaml
